{
    "name": "daniel-jorg-schuppelius/php-api-toolkit",
    "description": "Reused codes for my api php sdks",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Daniel Joerg Schuppelius",
            "email": "info@schuppelius.org"
        }
    ],
    "prefer-stable": true,
    "require": {
        "php": ">=8.1 <8.6",
        "guzzlehttp/guzzle": "^7.10",
        "dschuppelius/php-common-toolkit": "^1.0",
        "dschuppelius/php-error-toolkit": "^2.4",
        "ramsey/uuid": "^4.9"
    },
    "autoload": {
        "psr-4": {
            "APIToolkit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.3",
        "laravel/pint": "^1.27",
        "phpstan/phpstan": "^2.1"
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "format": "vendor/bin/pint --test",
        "format:fix": "vendor/bin/pint",
        "lint": "vendor/bin/phpstan analyse --memory-limit=1G",
        "qa": [
            "@format",
            "@lint",
            "@test"
        ]
    }
}